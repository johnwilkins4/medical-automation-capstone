# Copy this to .env and fill in your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: model overrides
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: paths (defaults are sensible)
DB_PATH=healthcare.db
FAISS_HP_PATH=indices/hp_index
FAISS_MEDICAL_PATH=indices/medical_index
